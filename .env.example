# ---------------------------------------------------------------------------
# Chat Link — environment template
#
# Copy this file to `.env.local` and fill in real values:
#     cp .env.example .env.local
#
# `.env.local` is gitignored. NEVER commit real keys or secrets.
# Only variables prefixed with NEXT_PUBLIC_ are exposed to the browser —
# everything else stays server-side.
# ---------------------------------------------------------------------------

# Canonical origin. Used for metadata, Open Graph URLs, sitemap.xml, robots.txt.
# Local dev: http://localhost:3000 — Production: https://chat-link.net
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ---------------------------------------------------------------------------
# Contact form (NOT WIRED UP YET)
#
# The contact form currently logs to the console — see the TODO in
# src/components/sections/contact-form.tsx. When you add a backend route
# handler, read its credentials from variables like these. They are reserved
# here so no one is tempted to hardcode them later.
# ---------------------------------------------------------------------------

# Transactional email provider key, for delivering form submissions.
# CONTACT_EMAIL_API_KEY=""

# Where contact-form submissions should be delivered.
# CONTACT_FORM_RECIPIENT="sales@chat-link.net"

# Spam protection for the contact form (e.g. hCaptcha / Turnstile).
# CAPTCHA_SECRET_KEY=""
# NEXT_PUBLIC_CAPTCHA_SITE_KEY=""

# ---------------------------------------------------------------------------
# Analytics (optional)
# ---------------------------------------------------------------------------
# NEXT_PUBLIC_ANALYTICS_ID=""
